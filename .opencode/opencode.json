{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "enabled_providers": [
    "azure-anthropic"
  ],
  "model": "azure-anthropic/claude-opus-4-7",
  "small_model": "azure-anthropic/claude-opus-4-7",
  "default_agent": "ci",
  "permission": {
    "*": "allow",
    "question": "deny",
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow"
  },
  "agent": {
    "ci": {
      "mode": "primary",
      "model": "azure-anthropic/claude-opus-4-7",
      "description": "CI no-interactive (sin preguntas, sin plan mode), con continuidad para tareas largas.",
      "prompt": "Eres un agente autónomo en GitHub Actions. PROHIBIDO hacer preguntas o pedir confirmación. NO uses plan mode. Ejecuta directamente, escribe archivos cuando haga falta y deja un resumen incremental al final de cada fase. Si falta información, asume valores razonables y documenta supuestos."
    },
    "build": {
      "mode": "subagent",
      "model": "azure-anthropic/claude-opus-4-7",
      "prompt": "Eres el subagente build. Ejecuta tareas y escribe archivos sin preguntas ni confirmaciones. Si falta info, asume valores razonables y continúa."
    },
    "plan": {
      "disable": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "target/**",
      ".git/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "lsp": false,
  "formatter": false,
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@zenobius/opencode-skillful"
  ],
  "mcp": {
    "mcp_memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_sequential_thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "timeout": 5000
    }
  },
  "provider": {
    "azure-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Azure Anthropic Foundry",
      "options": {
        "baseURL": "https://opencoder-resource.openai.azure.com/anthropic/v1",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {env:AZURE_OPENAI_API_KEY}",
            "anthropic-version": "2023-06-01"
          },
        "timeout": 120000
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "cost": {
            "input": 0,
            "output": 0
          },
          "options": {
            "temperature": 0.2,
            "top_p": 0.9
          }
        }
      }
    }
  }
}
