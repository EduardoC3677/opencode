{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure AI Foundry (Chat Completions)",
      "options": {
        // Tu curl pega directo aquí:
        "baseURL": "https://eduardoc-6482-resource.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview",
        "headers": {
          // Igual que tu curl
          "Authorization": "Bearer {env:AZURE_OPENAI_API_KEY}",
          "Content-Type": "application/json"
        }
      },
      "models": {
        "Codestral-2501": {
          "name": "Codestral 2501",
          "streamUsage": false,
          "limit": { "context": 32768, "output": 2048 },
          "cost": { "input": 0, "output": 0 }
        },

        "DeepSeek-R1": {
          "name": "DeepSeek R1",
          // Rate limit que pegaste: 1,000 TPM / 1 RPM (solo nota)
          "limit": { "context": 32768, "output": 2048 },
          "cost": { "input": 0, "output": 0 }
        },

        "DeepSeek-V3.2": {
          "name": "DeepSeek V3.2",
          // Rate limit: 20,000 TPM / 20 RPM (solo nota)
          "limit": { "context": 32768, "output": 2048 },
          "cost": { "input": 0, "output": 0 }
        },

        "DeepSeek-V3.2-Speciale": {
          "name": "DeepSeek V3.2 Speciale",
          // Rate limit: 20,000 TPM / 20 RPM (solo nota)
          "limit": { "context": 32768, "output": 2048 },
          "cost": { "input": 0, "output": 0 }
        },

        "DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          // Rate limit: 20,000 TPM / 20 RPM (solo nota)
          "limit": { "context": 32768, "output": 16384 },
          "cost": { "input": 0, "output": 0 }
        },

        "Kimi-K2.6": {
          "name": "Kimi K2.6",
          // Rate limit: 20,000 TPM / 20 RPM (solo nota)
          "limit": { "context": 32768, "output": 2048 },
          "cost": { "input": 0, "output": 0 }
        }
      }
    },

    "azure-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Azure Anthropic Foundry",
      "options": {
        // Tu curl pega a /anthropic/v1/messages
        // El SDK normalmente construye /v1/messages, por eso dejamos baseURL en el prefijo /anthropic/
        "baseURL": "https://eduardoc-6482-resource.services.ai.azure.com/anthropic/",
        "headers": {
          "x-api-key": "{env:AZURE_ANTHROPIC_API_KEY}",
          "anthropic-version": "2023-06-01",
          "Content-Type": "application/json"
        }
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          // Rate limit: 350,000 TPM / 350 RPM (solo nota)
          "limit": { "context": 200000, "output": 1000 },
          "cost": { "input": 0, "output": 0 }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          // Rate limit: 450,000 TPM / 450 RPM (solo nota)
          "limit": { "context": 200000, "output": 1000 },
          "cost": { "input": 0, "output": 0 }
        }
      }
    },

    "azure-cognitive": {
      // IMPORTANTE: tu curl usa Responses API:
      // POST https://...cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
      // y header Authorization: Bearer ...
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure Cognitive Services (Responses API)",
      "options": {
        "baseURL": "https://eduardoc-6482-resource.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview",
        "headers": {
          "Authorization": "Bearer {env:AZURE_COGNITIVE_API_KEY}",
          "Content-Type": "application/json"
        }
      },
      "models": {
        "gpt-5.4-pro": {
          "name": "GPT 5.4 Pro",
          // Rate limit: 100,000 TPM / 100 RPM (solo nota)
          "limit": { "context": 131072, "output": 16384 },
          "cost": { "input": 0, "output": 0 }
        }
      }
    },

    "azure-echoais": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure Echoais (Responses API)",
      "options": {
        "baseURL": "https://echoais.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview",
        "headers": {
          "Authorization": "Bearer {env:AZURE_ECHOAIS_API_KEY}",
          "Content-Type": "application/json"
        }
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          // Rate limit: 1,000,000 TPM / 10,000 RPM (solo nota)
          "limit": { "context": 131072, "output": 16384 },
          "cost": { "input": 0, "output": 0 }
        }
      }
    }
  },

  "agent": {
    "auto-review": {
      "description": "Automatic PR review triggered on PR open/sync",
      "mode": "primary",
      "hidden": true,
      "model": "azure-openai/DeepSeek-V4-Flash",
      "temperature": 0.1
    },
    "manual-review": {
      "description": "Manual PR review triggered via /oc or /opencode",
      "mode": "primary",
      "hidden": true,
      "model": "azure-openai/DeepSeek-V4-Flash",
      "temperature": 0.1
    }
  },

  "watcher": {
    "ignore": [".opencode/node_modules/**"]
  }
}
