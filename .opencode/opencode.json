{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure OpenAI (OpenAI Compatible)",
      "options": {
        "baseURL": "https://eduardoc-6482-resource.services.ai.azure.com/openai/v1/",
        "headers": {
          "api-key": "{env:AZURE_OPENAI_API_KEY}"
        }
      },
      "models": {
        "Codestral-2501": {
          "name": "Codestral 2501",
          "streamUsage": false,
          "limit": {
            "context": 32768,
            "output": 2048
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          "limit": {
            "context": 32768,
            "output": 16384
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "DeepSeek-V3.2": {
          "name": "DeepSeek V3.2",
          "limit": {
            "context": 32768,
            "output": 2048
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "DeepSeek-V3.2-Speciale": {
          "name": "DeepSeek V3.2 Speciale",
          "limit": {
            "context": 32768,
            "output": 2048
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "Kimi-K2.6": {
          "name": "Kimi K2.6",
          "limit": {
            "context": 32768,
            "output": 2048
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        }
      }
    },
    "azure-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Azure Anthropic Foundry",
      "options": {
        "baseURL": "https://eduardoc-6482-resource.services.ai.azure.com/anthropic/",
        "headers": {
          "x-api-key": "{env:AZURE_ANTHROPIC_API_KEY}"
        }
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "limit": {
            "context": 200000,
            "output": 1000
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "limit": {
            "context": 200000,
            "output": 1000
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        }
      }
    },
    "azure-cognitive": {
      "npm": "@ai-sdk/azure",
      "name": "Azure Cognitive Services",
      "options": {
        "baseURL": "https://eduardoc-6482-resource.cognitiveservices.azure.com/",
        "headers": {
          "api-key": "{env:AZURE_COGNITIVE_API_KEY}"
        }
      },
      "models": {
        "gpt-5.4-pro": {
          "name": "GPT 5.4 Pro",
          "limit": {
            "context": 131072,
            "output": 16384
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        }
      }
    },
    "azure-echoais": {
      "npm": "@ai-sdk/azure",
      "name": "Azure Echoais",
      "options": {
        "baseURL": "https://echoais.cognitiveservices.azure.com/",
        "headers": {
          "api-key": "{env:AZURE_ECHOAIS_API_KEY}"
        }
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          "limit": {
            "context": 131072,
            "output": 16384
          },
          "cost": {
            "input": 0,
            "output": 0
          }
        }
      }
    }
  },
  "mcpServers": {
    "sequential-thinking": {
      "url": "https://mcp-dvthn8n6d3e6.sequoia.mcp.com"
    },
    "playwright": {
      "command": "npx",
      "args": ["@anthropic/mcp-playwright"]
    },
    "memory": {
      "command": "npx",
      "args": ["@anthropic/mcp-memory"]
    },
    "github": {
      "command": "npx",
      "args": ["@anthropic/mcp-github"]
    }
  },
  "plugins": [
    {
      "name": "agent",
      "path": ".opencode/agent"
    },
    {
      "name": "command",
      "path": ".opencode/command"
    }
  ],
  "agents": {
    "model": "sonic-fast"
  },
  "thoughts": "thoughts",
  "watcher": {
    "ignore": [
      ".opencode/node_modules/**"
    ]
  }
}
