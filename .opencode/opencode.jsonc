{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "azure-foundry": {
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "baseURL": "https://openslab-resource.openai.azure.com/openai/v1"
      },
      "models": {
        "gpt-5.3-mini": {
          "name": "GPT 5.3-mini (Azure)",
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "parallelToolCalls": true
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3-codex (Azure)",
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "parallelToolCalls": true
          }
        }
      }
    }
  },
  "model": "azure-foundry/gpt-5.3-codex",
  "small_model": "azure-foundry/gpt-5.3-mini",
  "default_agent": "task",
  "agent": {
    "code-review": {
      "model": "azure-foundry/gpt-5.3-codex",
      "temperature": 0.1,
      "reasoningEffort": "low",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git --no-pager status*": "allow",
          "git --no-pager diff*": "allow",
          "git --no-pager log*": "allow",
          "git --no-pager show*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "rg *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow"
        }
      }
    },
    "configure-opencode": {
      "model": "azure-foundry/gpt-5.3-mini",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "deny",
          "opencode mcp list*": "allow",
          "opencode mcp show*": "allow",
          "opencode mcp validate*": "allow",
          "opencode mcp reload*": "allow",
          "opencode mcp status*": "allow",
          "jq *": "allow",
          "python -m json.tool *": "allow"
        }
      }
    },
    "explore": {
      "model": "azure-foundry/gpt-5.3-mini",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "tree *": "allow",
          "pwd": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "uname*": "allow",
          "hostname": "allow",
          "whoami": "allow",
          "which *": "allow",
          "realpath *": "allow"
        }
      }
    },
    "research": {
      "model": "azure-foundry/gpt-5.3-codex",
      "temperature": 0.4,
      "reasoningEffort": "medium",
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep_*": "allow",
        "webfetch": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh run view*": "allow",
          "gh run list*": "allow",
          "gh workflow list*": "allow",
          "gh search *": "allow",
          "gh api --method GET *": "allow",
          "npm view*": "allow",
          "npm info*": "allow",
          "npm show*": "allow"
        }
      }
    },
    "task": {
      "model": "azure-foundry/gpt-5.3-codex",
      "temperature": 0.1,
      "reasoningEffort": "low",
      "permission": {
        "task": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "rg *": "allow",
          "npm run test*": "allow",
          "npm run build*": "allow",
          "npm run lint*": "allow",
          "npm run format*": "allow",
          "npm run check*": "allow",
          "npm run typecheck*": "allow",
          "npm test*": "allow",
          "npx eslint *": "allow",
          "npx prettier *": "allow",
          "npx tsc *": "allow",
          "pnpm run test*": "allow",
          "pnpm run build*": "allow",
          "pnpm run lint*": "allow",
          "pnpm run format*": "allow",
          "pnpm run check*": "allow",
          "pnpm run typecheck*": "allow",
          "pnpm test*": "allow",
          "yarn run test*": "allow",
          "yarn run build*": "allow",
          "yarn run lint*": "allow",
          "yarn run format*": "allow",
          "yarn run check*": "allow",
          "yarn run typecheck*": "allow",
          "yarn test*": "allow",
          "bun run test*": "allow",
          "bun run build*": "allow",
          "bun run lint*": "allow",
          "bun run format*": "allow",
          "bun run check*": "allow",
          "bun run typecheck*": "allow",
          "bun test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "go test*": "allow",
          "go build*": "allow",
          "cargo test*": "allow",
          "cargo build*": "allow",
          "cargo check*": "allow",
          "cargo clippy*": "allow",
          "cargo fmt*": "allow",
          "ruff *": "allow",
          "eslint *": "allow",
          "prettier *": "allow",
          "tsc *": "allow"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "permission": {
    "task": "deny",
    "context7_*": "deny",
    "exa_*": "deny",
    "gh_grep_*": "deny",
    "kagi_*": "deny",
    "webfetch": "deny",
    "worktree_*": "deny"
  },
  "instructions": [
    "./tools/philosophy.md"
  ],
  "plugin": [
    "@tarquinen/opencode-dcp@3.1.3",
    "@franlol/opencode-md-table-formatter@0.0.6",
    "./plugins/background-agents.ts",
    "./plugins/workspace-plugin.ts"
  ]
}
