{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "enabled_providers": [
    "azure-openai"
  ],
  "model": "azure-openai/DeepSeek-V4-Flash",
  "small_model": "azure-openai/DeepSeek-V4-Flash",
  "default_agent": "ci",
  "permission": {
    "*": "allow",
    "question": "deny",
    "doom_loop": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    }
  },
  "agent": {
    "ci": {
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "description": "Agente primary no-interactive para CI/GitHub Actions (sin preguntas, sin confirmaciones).",
      "prompt": "Eres un agente autónomo que corre en GitHub Actions. PROHIBIDO pedir confirmación, pedir que el usuario elija, o hacer preguntas. NO termines con 'continue' ni solicites aprobación. Si falta información, asume valores razonables y continúa con el primer paso seguro. Ejecuta, registra resultados y deja pendientes claros al final.",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 12,
      "options": {
        "reasoningEffort": "medium"
      },
      "permission": {
        "*": "allow",
        "question": "deny",
        "doom_loop": "allow",
        "external_directory": "allow",
        "bash": {
          "*": "allow"
        },
        "read": {
          "*": "allow"
        }
      }
    },
    "build": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "prompt": "Eres el subagente build. Ejecuta tareas de implementación y cambios en repo sin hacer preguntas al usuario. Si falta información, asume valores razonables y continúa.",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 12,
      "options": {
        "reasoningEffort": "medium"
      },
      "permission": {
        "*": "allow",
        "question": "deny",
        "doom_loop": "allow",
        "external_directory": "allow",
        "bash": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    },
    "scout": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "target/**",
      ".git/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "lsp": false,
  "formatter": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "fetch": {
      "type": "remote",
      "url": "https://remote.mcpservers.org/fetch/mcp",
      "enabled": true
    },
    "mcp_memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_sequential_thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": false,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "timeout": 5000
    }
  },
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure OpenAI (OpenAI Compatible)",
      "options": {
        "baseURL": "https://opencoder-resource.services.ai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "headers": {
          "api-key": "{env:AZURE_OPENAI_API_KEY}"
        },
        "timeout": 600000
      },
      "models": {
        "DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "cost": {
            "input": 0,
            "output": 0
          },
          "options": {
            "temperature": 0.2,
            "top_p": 0.9,
            "frequency_penalty": 0.2,
            "presence_penalty": 0,
            "parallel_tool_calls": true,
            "tool_choice": "auto",
            "reasoningEffort": "medium"
          }
        }
      }
    }
  }
}
