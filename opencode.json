{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "enabled_providers": [
    "azure-openai"
  ],
  "model": "azure-openai/DeepSeek-V4-Flash",
  "small_model": "azure-openai/DeepSeek-V4-Flash",
  "default_agent": "ci",
  "permission": {
    "*": "allow",
    "question": "deny",
    "doom_loop": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    }
  },
  "agent": {
    "ci": {
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "description": "Agente primary no-interactive para CI/GitHub Actions (sin preguntas, sin confirmaciones).",
      "prompt": "Eres un agente autónomo que corre en GitHub Actions. PROHIBIDO pedir confirmación o hacer preguntas al usuario. Si falta información, asume valores razonables y continúa. Produce un plan breve y ejecútalo. Al final, documenta supuestos y resultados. No pidas al usuario elegir opciones: decide tú y avanza.",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 40,
      "options": {
        "reasoningEffort": "max"
      },
      "permission": {
        "*": "allow",
        "question": "deny",
        "doom_loop": "allow",
        "external_directory": "allow",
        "bash": {
          "*": "allow"
        },
        "read": {
          "*": "allow"
        }
      }
    },
    "build": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "prompt": "Eres el subagente build. Ejecuta tareas de implementación y cambios en repo sin hacer preguntas al usuario. Si falta información, asume valores razonables y continúa.",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 40,
      "options": {
        "reasoningEffort": "max"
      },
      "permission": {
        "*": "allow",
        "question": "deny",
        "doom_loop": "allow",
        "external_directory": "allow",
        "bash": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    },
    "scout": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "permission": {
        "*": "allow",
        "question": "deny"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "target/**",
      ".git/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "lsp": false,
  "formatter": false,
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure OpenAI (OpenAI Compatible)",
      "options": {
        "baseURL": "https://opencoder-resource.services.ai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "headers": {
          "api-key": "{env:AZURE_OPENAI_API_KEY}"
        },
        "timeout": 600000
      },
      "models": {
        "DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 65536
          },
          "cost": {
            "input": 0,
            "output": 0
          },
          "options": {
            "temperature": 0.2,
            "top_p": 0.9,
            "frequency_penalty": 0.2,
            "presence_penalty": 0,
            "parallel_tool_calls": true,
            "tool_choice": "auto",
            "reasoningEffort": "max"
          }
        }
      }
    }
  }
}
