{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "enabled_providers": [
    "azure-openai"
  ],
  "model": "azure-openai/DeepSeek-V4-Flash",
  "small_model": "azure-openai/DeepSeek-V4-Flash",
  "default_agent": "ci",
  "permission": {
    "*": "allow",
    "question": "deny",
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow"
  },
  "agent": {
    "ci": {
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "description": "Agente primary no-interactive para CI/GitHub Actions (sin preguntas ni planning).",
      "prompt": "Eres un agente autónomo en GitHub Actions. PROHIBIDO hacer preguntas o pedir confirmación. No uses 'plan mode' ni pidas al usuario elegir opciones. Ejecuta directamente y registra resultados. Si falta información, asume valores razonables y documenta supuestos al final. Mantén continuidad: actualiza un resumen breve de estado al finalizar cada fase.",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 6,
      "options": {
        "reasoningEffort": "low"
      },
      "permission": {
        "*": "allow",
        "question": "deny",
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "doom_loop": "allow",
        "external_directory": "allow"
      }
    },
    "build": {
      "mode": "subagent",
      "model": "azure-openai/DeepSeek-V4-Flash",
      "prompt": "Eres el subagente build. Ejecuta tareas de implementación y escritura de archivos sin preguntas ni confirmaciones. Si falta info, asume valores razonables y continúa.",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 6,
      "options": {
        "reasoningEffort": "low"
      },
      "permission": {
        "*": "allow",
        "question": "deny",
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "doom_loop": "allow",
        "external_directory": "allow"
      }
    },
    "plan": {
      "disable": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "target/**",
      ".git/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "lsp": false,
  "formatter": false,
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@zenobius/opencode-skillful"
  ],
  "mcp": {
    "mcp_memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_sequential_thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "timeout": 5000
    }
  },
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure OpenAI (OpenAI Compatible)",
      "options": {
        "baseURL": "https://opencoder-resource.services.ai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "headers": {
          "api-key": "{env:AZURE_OPENAI_API_KEY}"
        },
        "timeout": 120000,
        "chunkTimeout": 10000
      },
      "models": {
        "DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash",
          "tool_call": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 4096
          },
          "cost": {
            "input": 0,
            "output": 0
          },
          "options": {
            "temperature": 0.2,
            "top_p": 0.9,
            "parallel_tool_calls": true,
            "tool_choice": "auto",
            "reasoningEffort": "low"
          }
        }
      }
    }
  }
}
