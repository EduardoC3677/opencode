{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "enabled_providers": ["azure-openai"],
  "model": "azure-openai/DeepSeek-V4-Pro",
  "small_model": "azure-openai/DeepSeek-V4-Pro",
  "default_agent": "build",
  "permission": {
    "*": "allow",
    "question": "deny",
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Pro"
    },
    "plan": {
      "disable": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "target/**",
      ".git/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "lsp": true,
  "formatter": false,
  "mcp": {
    "mcp_memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_sequential_thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 5000
    },
    "mcp_github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "timeout": 5000
    }
  },
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/deepseek",
      "name": "Azure OpenAI",
      "options": {
        "apiKey": "{env:AZURE_API_KEY}",
        "baseURL": "https://openslab-resource.services.ai.azure.com/openai/v1",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer {env:AZURE_API_KEY}"
        },
      },
      "models": {
        "DeepSeek-V4-Pro": {
          "name": "DeepSeek-V4-Pro",
          "deployment": "DeepSeek-V4-Pro",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 16384
          },
          "cost": {
            "input": 0,
            "output": 0
          },
          "options": {
            "temperature": 0.8,
            "top_p": 0.1,
            "presence_penalty": 0,
            "frequency_penalty": 0
          }
        }
      }
    }
  }
}
