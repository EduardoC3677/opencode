{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,

  "enabled_providers": ["azure-openai"],

  "model": "azure-openai/DeepSeek-V4-Pro",
  "small_model": "azure-openai/DeepSeek-V4-Pro-Low",
  "default_agent": "build",

  "permission": {
    "*": "allow",
    "question": "deny",

    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",

    "task": "allow",
    "skill": "allow",

    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "deny",

    "bash": {
      "*": "allow"
    }
  },

  "agent": {
    "build": {
      "description": "Agente autónomo de desarrollo de software para CI/CD, optimizado para bajo consumo de tokens y sin interacción con el usuario.",
      "mode": "primary",
      "model": "azure-openai/DeepSeek-V4-Pro",

      "steps": 12,

      "prompt": "Eres un ingeniero de software senior ejecutándose en CI/CD no interactivo. No hagas preguntas, no pidas confirmación, no cierres con preguntas, no propongas planes ni listas de pasos. Decide y ejecuta la opción más razonable por tu cuenta. Si falta información, asume lo mínimo necesario, continúa y deja supuestos breves en RUN_LOG.md. Trabaja sobre el repositorio local: inspecciona solo lo necesario, diagnostica fallos, aplica el cambio mínimo, actualiza pruebas si corresponde y ejecuta verificaciones locales. Minimiza tokens: evita repetir contexto, evita logs completos, no hagas dumps grandes, no leas archivos binarios completos, no hagas búsquedas sin límite y limita cada salida con head, tail o sed a un máximo de 80 líneas relevantes. No uses web, fetch externo, GitHub ni memoria externa. Mantén RUN_LOG.md breve, útil y de no más de 120 líneas. Finaliza con un cierre corto: archivos cambiados, validación, riesgos y siguientes pasos, sin pedir instrucciones adicionales.",

      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": true,
        "bash": true,
        "task": true,
        "skill": true,
        "webfetch": true,
        "websearch": true
      },

      "permission": {
        "*": "allow",
        "question": "deny",

        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",

        "task": "allow",
        "skill": "allow",

        "webfetch": "allow",
        "websearch": "allow",
        "external_directory": "deny",

        "bash": {
          "*": "allow"
        }
      },

      "options": {
        "maxOutputTokens": 1400,
        "reasoningEffort": "low"
      }
    },

    "plan": {
      "disable": true
    }
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 2500
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "target/**",
      ".git/**",
      ".venv/**",
      "venv/**",
      "coverage/**",
      ".next/**",
      ".turbo/**",
      ".cache/**"
    ]
  },

  "lsp": false,
  "formatter": false,

  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure OpenAI compatible endpoint via @ai-sdk/deepseek",

      "options": {
        "baseURL": "https://openslab-resource.services.ai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "headers": {
          "api-key": "{env:AZURE_OPENAI_API_KEY}"
        },
        "timeout": 150000,
        "chunkTimeout": 30000
      },

      "models": {
        "DeepSeek-V4-Pro": {
          "name": "DeepSeek-V4-Pro",
          "reasoning": true,
          "tool_call": true,

          "cost": {
            "input": 0,
            "output": 0,
            "cache_read": 0,
            "cache_write": 0
          },

          "limit": {
            "context": 12000,
            "input": 9000,
            "output": 1400
          },

          "options": {
            "maxOutputTokens": 1400,
            "reasoningEffort": "low"
          }
        },

        "DeepSeek-V4-Pro-Low": {
          "name": "DeepSeek-V4-Pro",
          "reasoning": true,
          "tool_call": true,
        
          "cost": {
            "input": 0,
            "output": 0,
            "cache_read": 0,
            "cache_write": 0
          },

          "limit": {
            "context": 8000,
            "input": 6000,
            "output": 800
          },

          "options": {
            "maxOutputTokens": 800,
            "reasoningEffort": "low"
          }
        }
      }
    }
  }
}
