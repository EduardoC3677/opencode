# === REQUIRED ===
# GitHub App credentials (from your GitHub App settings)
APP_ID=123456
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
WEBHOOK_SECRET=your-webhook-secret-here

# GitHub App client credentials (for OAuth)
CLIENT_ID=Iv1.your-client-id
CLIENT_SECRET=your-client-secret

# === OPENCODE CONFIGURATION ===
# Path to the opencode config directory (contains opencode.jsonc, agents, skills, plugins)
OPENCODE_CONFIG_DIR=.opencode

# AI Provider API key (Azure OpenAI, etc.)
AZURE_OPENAI_API_KEY=your-azure-api-key

# Default model to use
OPENCODE_MODEL=deepseek/deepseek-v4-pro

# === OPTIONAL ===
# Port for the webhook server
PORT=3000

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Maximum execution time per task in seconds (default: 900 = 15 min)
TASK_TIMEOUT=900

# Comma-separated list of allowed repositories (owner/repo). Empty = all installations allowed
ALLOWED_REPOS=

# Comma-separated list of blocked repositories (owner/repo)
BLOCKED_REPOS=