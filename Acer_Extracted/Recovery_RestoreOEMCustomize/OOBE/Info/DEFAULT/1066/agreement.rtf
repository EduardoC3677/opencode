\u7885?\f0\lang1033 . Th\'f4ng b\'e1o v\f1\lang1066\u7873?\f0\lang1033  quy\f1\lang1066\u7873?n ri\'eang t\'fd (\ldblquote Th\'f4ng b\'e1o\rdblquote ) n\'e0y \'f0\'fd\u7907?\f0\lang1033 c bi\'ean so\f1\lang1066\u7841?\f2\lang1033 n \'f0\f1\lang1066\u7875?\f0\lang1033  th\'f4ng b\'e1o cho b\f1\lang1066\u7841?\f0\lang1033 n v\f1\lang1066\u7873?\f0\lang1033  c\'e1ch ch\'fang t\'f4i thu th\f1\lang1066\u7853?\f0\lang1033 p, s\f1\lang1066\u7917?\f0\lang1033  d\f1\lang1066\u7909?\f0\lang1033 ng v\'e0 chia s\f1\lang1066\u7867?\f0\lang1033  d\f1\lang1066\u7919?\f0\lang1033  li\f1\lang1066\u7879?\f0\lang1033 u c\'e1 nh\'e2n c\f1\lang1066\u7911?\f0\lang1033 a b\f1\lang1066\u7841?\f0\lang1033 n th\'f4ng qua trang web (\ldblquote Trang web\rdblquote  c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i), c\'e1c s\f1\lang1066\u7843?\f0\lang1033 n ph\f1\lang1066\u7849?\f0\lang1033 m, d\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  v\'e0 \f1\lang1066\u7913?\f0\lang1033 ng d\f1\lang1066\u7909?\f0\lang1033 ng tr\'ean n\f1\lang1066\u7873?n web v\'e0 di \'f0\u7897?\f0\lang1033 ng c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i (g\f1\lang1066\u7885?\f0\lang1033 i chung l\'e0 \ldblquote D\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033\rdblquote ) ho\f1\lang1066\u7863?\f0\lang1033 c khi b\f1\lang1066\u7841?n t\'fd\'f5ng t\'e1c v\u7899?\f0\lang1033 i ch\'fang t\'f4i.\par
McAfee b\'e1n c\'e1c s\f1\lang1066\u7843?\f0\lang1033 n ph\f1\lang1066\u7849?\f0\lang1033 m v\'e0 d\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  tr\f1\lang1066\u7921?\f0\lang1033 c ti\f1\lang1066\u7871?p cho ng\'fd\u7901?\f0\lang1033 i ti\'eau d\'f9ng (b\f1\lang1066\u7841?\f0\lang1033 n c\'f3 th\f1\lang1066\u7875?\f0\lang1033  t\'ecm th\'eam th\'f4ng tin v\f1\lang1066\u7873?\f0\lang1033  c\'e1c s\f1\lang1066\u7843?\f0\lang1033 n ph\f1\lang1066\u7849?\f2\lang1033 m \'f0\'f3 t\f1\lang1066\u7841?\f2\lang1033 i \'f0\'e2y, \ldblquote S\f1\lang1066\u7843?\f0\lang1033 n ph\f1\lang1066\u7849?m d\'e0nh cho ng\'fd\u7901?\f0\lang1033 i ti\'eau d\'f9ng\rdblquote ). Th\'f4ng b\'e1o v\f1\lang1066\u7873?\f0\lang1033  quy\f1\lang1066\u7873?n ri\'eang t\'fd n\'e0y \'e1p d\u7909?\f0\lang1033 ng cho th\'f4ng tin ch\'fang t\'f4i thu th\f1\lang1066\u7853?\f0\lang1033 p t\f1\lang1066\u7915?\f0\lang1033  b\f1\lang1066\u7841?\f0\lang1033 n ho\f1\lang1066\u7863?\f0\lang1033 c thi\f1\lang1066\u7871?\f0\lang1033 t b\f1\lang1066\u7883?\f0\lang1033  c\f1\lang1066\u7911?\f0\lang1033 a b\f1\lang1066\u7841?\f0\lang1033 n khi b\f1\lang1066\u7841?\f0\lang1033 n t\f1\lang1066\u7843?\f0\lang1033 i xu\f1\lang1066\u7889?\f0\lang1033 ng m\f1\lang1066\u7897?\f0\lang1033 t trong c\'e1c D\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i v\'e0 cho c\f1\lang1066\u7843?\f0\lang1033  th\'f4ng tin ch\'fang t\'f4i thu th\f1\lang1066\u7853?\f0\lang1033 p khi m\f1\lang1066\u7897?\f0\lang1033 t trong nh\f1\lang1066\u7919?\f2\lang1033 ng \'f0\f1\lang1066\u7889?\f0\lang1033 i t\'e1c ph\'e2n ph\f1\lang1066\u7889?i c\'e0i \'f0\u7863?\f0\lang1033 t D\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i tr\'ean thi\f1\lang1066\u7871?\f0\lang1033 t b\f1\lang1066\u7883?\f0\lang1033  c\f1\lang1066\u7911?\f0\lang1033 a b\f1\lang1066\u7841?\f0\lang1033 n.\par
Khi b\f1\lang1066\u7841?\f0\lang1033 n truy c\f1\lang1066\u7853?\f0\lang1033 p ho\f1\lang1066\u7863?\f0\lang1033 c s\f1\lang1066\u7917?\f0\lang1033  d\f1\lang1066\u7909?\f0\lang1033 ng D\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i, b\f1\lang1066\u7841?\f0\lang1033 n th\f1\lang1066\u7915?\f0\lang1033 a nh\f1\lang1066\u7853?\f0\lang1033 n r\f1\lang1066\u7857?\f0\lang1033 ng b\f1\lang1066\u7841?\f2\lang1033 n \'f0\f0\'e3 \f3\'f0\f1\lang1066\u7885?\f0\lang1033 c Th\'f4ng b\'e1o n\'e0y v\'e0 hi\f1\lang1066\u7875?\f0\lang1033 u n\f1\lang1066\u7897?\f2\lang1033 i dung trong \'f0\'f3. Vi\f1\lang1066\u7879?\f0\lang1033 c b\f1\lang1066\u7841?\f0\lang1033 n s\f1\lang1066\u7917?\f0\lang1033  d\f1\lang1066\u7909?\f0\lang1033 ng c\'e1c D\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  c\f1\lang1066\u7911?a ch\'fang t\'f4i v\'e0 Trang web c\f4\u361?\f1 ng nh\'fd b\u7845?\f0\lang1033 t k\f1\lang1066\u7923?\f0\lang1033  tranh ch\f1\lang1066\u7845?\f0\lang1033 p n\'e0o v\f1\lang1066\u7873?\f0\lang1033  quy\f1\lang1066\u7873?n ri\'eang t\'fd ph\u7843?\f0\lang1033 i tu\'e2n th\f1\lang1066\u7911?\f0\lang1033  Th\'f4ng b\'e1o n\'e0y, m\f1\lang1066\u7885?\f2\lang1033 i \'d0i\f1\lang1066\u7873?\f0\lang1033 u kho\f1\lang1066\u7843?\f0\lang1033 n d\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  c\'f3 th\f1\lang1066\u7875?\f0\lang1033  \'e1p d\f1\lang1066\u7909?\f0\lang1033 ng (bao g\f1\lang1066\u7891?\f0\lang1033 m m\f1\lang1066\u7885?\f0\lang1033 i gi\f1\lang1066\u7899?\f0\lang1033 i h\f1\lang1066\u7841?\f0\lang1033 n v\f1\lang1066\u7873?\f0\lang1033  thi\f1\lang1066\u7879?\f0\lang1033 t h\f1\lang1066\u7841?\f0\lang1033 i c\'f3 th\f1\lang1066\u7875?\f0\lang1033  \'e1p d\f1\lang1066\u7909?\f0\lang1033 ng v\'e0 vi\f1\lang1066\u7879?\f0\lang1033 c gi\f1\lang1066\u7843?\f0\lang1033 i quy\f1\lang1066\u7871?\f0\lang1033 t c\'e1c tranh ch\f1\lang1066\u7845?\f0\lang1033 p) v\'e0 m\f1\lang1066\u7885?\f0\lang1033 i Th\f1\lang1066\u7887?\f0\lang1033 a thu\f1\lang1066\u7853?\f0\lang1033 n c\f1\lang1066\u7845?p ph\'e9p ng\'fd\u7901?\f0\lang1033 i d\'f9ng cu\f1\lang1066\u7889?\f0\lang1033 i c\'f3 th\f1\lang1066\u7875?\f0\lang1033  \'e1p d\f1\lang1066\u7909?\f0\lang1033 ng.\par
Khi McAfee ph\'e1t tri\f1\lang1066\u7875?\f0\lang1033 n, ho\f1\lang1066\u7841?\f0\lang1033 t\f2  \'f0\f1\lang1066\u7897?\f0\lang1033 ng kinh doanh c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i s\f1\lang1066\u7869?\f2\lang1033  thay \'f0\f1\lang1066\u7893?\f0\lang1033 i v\'e0 ch\'fang t\'f4i c\'f3 th\f1\lang1066\u7875?\f0\lang1033  c\f1\lang1066\u7853?\f0\lang1033 p nh\f1\lang1066\u7853?\f0\lang1033 t Th\'f4ng b\'e1o n\'e0y v\'e0o b\f1\lang1066\u7845?\f0\lang1033 t c\f1\lang1066\u7913?\f0\lang1033  l\'fac n\'e0o ch\'fang t\'f4i cho l\'e0 ph\'f9 h\f1\lang1066\u7907?\f2\lang1033 p \'f0\f1\lang1066\u7875?\f0\lang1033  ph\f1\lang1066\u7843?\f0\lang1033 n \'e1nh nh\f1\lang1066\u7919?\f2\lang1033 ng thay \'f0\f1\lang1066\u7893?\f2\lang1033 i \'f0\'f3. N\f1\lang1066\u7871?\f0\lang1033 u c\'f3 b\f1\lang1066\u7845?\f0\lang1033 t k\f1\lang1066\u7923?\f2\lang1033  thay \'f0\f1\lang1066\u7893?\f0\lang1033 i quan tr\f1\lang1066\u7885?\f0\lang1033 ng n\'e0o v\f1\lang1066\u7899?\f0\lang1033 i Th\'f4ng B\'e1o V\f1\lang1066\u7873?\f0\lang1033  Quy\f1\lang1066\u7873?n Ri\'eang T\'fd n\'e0y, ch\'fang t\'f4i s\u7869?\f0\lang1033  th\'f4ng b\'e1o cho b\f1\lang1066\u7841?\f0\lang1033 n b\f1\lang1066\u7857?ng th\'fd \'f0i\u7879?\f0\lang1033 n t\f1\lang1066\u7917?\f0\lang1033 , b\f1\lang1066\u7857?\f0\lang1033 ng th\'f4ng b\'e1o trong s\f1\lang1066\u7843?\f0\lang1033 n ph\f1\lang1066\u7849?\f0\lang1033 m, ho\f1\lang1066\u7863?\f0\lang1033 c b\f1\lang1066\u7857?\f0\lang1033 ng c\'e1ch kh\'e1c theo y\'eau c\f1\lang1066\u7847?\f0\lang1033 u c\f1\lang1066\u7911?\f0\lang1033 a lu\f1\lang1066\u7853?\f0\lang1033 t hi\f1\lang1066\u7879?n h\'e0nh. \'d0i\u7873?\f0\lang1033 u quan tr\f1\lang1066\u7885?\f0\lang1033 ng l\'e0 b\f1\lang1066\u7841?\f0\lang1033 n c\f1\lang1066\u7847?\f0\lang1033 n ki\f1\lang1066\u7875?\f0\lang1033 m tra l\f1\lang1066\u7841?i v\'e0 \'f0\u7843?\f0\lang1033 m b\f1\lang1066\u7843?\f0\lang1033 o b\f1\lang1066\u7841?\f2\lang1033 n \'f0\f0\'e3 xem phi\'ean b\f1\lang1066\u7843?\f0\lang1033 n m\f1\lang1066\u7899?\f0\lang1033 i nh\f1\lang1066\u7845?\f0\lang1033 t c\f1\lang1066\u7911?\f0\lang1033 a Th\'f4ng B\'e1o n\'e0y.\par
Th\'f4ng b\'e1o n\'e0y \'e1p d\f1\lang1066\u7909?\f0\lang1033 ng cho t\f1\lang1066\u7845?\f0\lang1033 t c\f1\lang1066\u7843? ng\'fd\u7901?\f0\lang1033 i d\'f9ng c\'e1c D\f1\lang1066\u7883?\f0\lang1033 ch v\f1\lang1066\u7909?\f0\lang1033  c\f1\lang1066\u7911?\f0\lang1033 a ch\'fang t\'f4i tr\'ean to\'e0n th\f1\lang1066\u7871?\f0\lang1033  gi\f1\lang1066\u7899?\f0\lang1033 i. M\f1\lang1066\u7897?\f0\lang1033 t s\f1\lang1066\u7889? ng\'fd\u7901?\f0\lang1033 i d\'f9ng, bao g\f1\lang1066\u7891?\f0\lang1033 m c\f1\lang1066\u7843? c\'fd d\'e2n Khu v\u7921?\f0\lang1033 c kinh t\f1\lang1066\u7871?\f0\lang1033  ch\'e2u \'c2u, c\'f3 th\f1\lang1066\u7875?\f0\lang1033  c\'f3 c\'e1c quy\f1\lang1066\u7873?\f0\lang1033 n b\f1\lang1066\u7893?\f0\lang1033  sung t\'f9y thu\f1\lang1066\u7897?\f0\lang1033 c v\'e0o v\f1\lang1066\u7883?\f0\lang1033  tr\'ed c\f1\lang1066\u7911?\f0\lang1033 a h\f1\lang1066\u7885?, \'f0\'fd\u7907?\f0\lang1033 c m\'f4 t\f1\lang1066\u7843?\f0\lang1033  trong Th\'f4ng b\'e1o n\'e0y.\par
