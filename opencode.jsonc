{
  "$schema": "https://opencode.ai/config.json",
  "model": "azure-openai/DeepSeek-V4-Pro",
  "small_model": "azure-openai/DeepSeek-V4-Pro",
  "agent": {
    "plan": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 0.3,
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "build": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 0.3,
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "coder": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "explore": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "researcher": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 0.4,
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "scribe": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 1,
      "reasoningEffort": "low",
      "textVerbosity": "high"
    },
    "reviewer": {
      "model": "azure-openai/DeepSeek-V4-Pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    }
  },
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/deepseek",
      "name": "Azure DeepSeek compatible endpoint via @ai-sdk/deepseek",
      "options": {
        "baseURL": "https://openslab-resource.services.ai.azure.com/openai/v1",
        "apiKey": "{env:AZURE_OPENAI_API_KEY}"
      },
      "models": {
        "DeepSeek-V4-Pro": {
          "name": "DeepSeek-V4-Pro"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  }
}
